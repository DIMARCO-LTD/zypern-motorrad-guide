<script>
  // Handle language-specific elements that use class-based approach
  document.addEventListener('DOMContentLoaded', () => {
    function updateLangClasses() {
      const lang = localStorage.getItem('lang') || 'de';
      document.body.classList.toggle('lang-de', lang === 'de');
      document.body.classList.toggle('lang-en', lang === 'en');

      // Show/hide de-only and en-only elements
      document.querySelectorAll('.de-only').forEach(el => {
        el.style.display = lang === 'de' ? '' : 'none';
      });
      document.querySelectorAll('.en-only').forEach(el => {
        el.style.display = lang === 'en' ? '' : 'none';
      });
    }

    updateLangClasses();

    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', updateLangClasses);
    });
  });
</script>
